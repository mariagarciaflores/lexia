# Copia este archivo a ".env" y rellena con los valores de tu proyecto Firebase.
# El archivo .env está en .gitignore y NUNCA debe subirse al repositorio.
#
# Estos valores se obtienen en: Firebase Console > Configuración del proyecto >
# Tus apps > Configuración del SDK (objeto firebaseConfig).
# Nota: la apiKey de Firebase es un identificador público del proyecto, no una
# llave secreta. La verdadera seguridad la dan las reglas de Firestore y las
# restricciones de la API key en Google Cloud Console.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
